{
  "name": "@laniakea/apps",
  "version": "0.1.0",
  "description": "@laniakea/apps",
  "author": "GregRos",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "default": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "dist/index.js",
  "types": "dist/index",
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE.md",
    "package.json"
  ],
  "scripts": {
    "build": "tsc -b .",
    "clean": "shx rm -rf dist",
    "build:clean": "run-s clean build",
    "manifest": "tsx --tsconfig cluster/tsconfig.json ./cluster/run.ts",
    "prepare": "husky install",
    "tidy": "yarn install && run-s build:clean start",
    "start": "tsx --tsconfig ./cluster/tsconfig.json ./cluster/run.ts",
    "watch": "tsx --tsconfig ./cluster/tsconfig.json --watch ./cluster/run.ts",
    "delete-all": "kubectl delete -f ./k8s.out/",
    "apply": "kubectl apply -f ./k8s.out/",
    "lint:fix": "prettier --write src/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,ctsx,mtsx,html,htm,yaml,yml,json,scss,css} && eslint --fix src/**/*.{ts,mts,cts,js,mjs,cjs} ",
    "lint:check": "prettier --check src/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,ctsx,mtsx,html,htm,yaml,yml,json,scss,css} && eslint src/**/*.{ts,mts,cts,js,mjs,cjs}"
  },
  "lint-staged": {
    "*.{ts,mts,cts,js,mjs,cjs}": "node_modules/.bin/eslint --cache --fix",
    "src/**/*.{js,jsx,cjs,mjs,ts,tsx,cts,mts,ctsx,mtsx,html,htm,yaml,yml,json,scss,css}": "node_modules/.bin/prettier --write"
  },
  "resolutions": {
    "@k8ts/instruments": "portal:/C:/codegr/k8ts/packages/instruments",
    "@k8ts/metadata": "portal:/C:/codegr/k8ts/packages/metadata",
    "@k8ts/sample-interfaces": "portal:/C:/codegr/k8ts/packages/sample-interfaces",
    "k8ts": "portal:/C:/codegr/k8ts/packages/k8ts",
    "workspace": "portal:/C:/codegr/k8ts"
  },
  "dependencies": {
    "@k8ts/instruments": "^0.11.4",
    "@k8ts/metadata": "^0.10.3",
    "@k8ts/sample-interfaces": "^0.1.3",
    "doddle": "^7.3.1",
    "k8ts": "^0.13.3",
    "parjs": "^1.3.9",
    "yamprint": "^0.8.4"
  },
  "devDependencies": {
    "@types/lodash": "^4.17.15",
    "@types/node": "^22.12.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "lodash": "^4.17.21",
    "npm-run-all": "^4.1.5",
    "prettier": "^3.4.2",
    "prettier-plugin-jsdoc": "^1.3.2",
    "prettier-plugin-organize-imports": "^4.1.0",
    "prettier-plugin-packagejson": "^2.5.8",
    "shx": "^0.3.4",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  },
  "packageManager": "yarn@4.12.0",
  "sourcesRoot": "src"
}
